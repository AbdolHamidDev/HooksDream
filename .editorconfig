# EditorConfig - https://editorconfig.org
# This file helps maintain consistent coding styles across different editors and IDEs

# Top-level settings
root = true

# Default settings for all files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# Markdown files
[*.md]
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Python files
[*.py]
indent_size = 4
max_line_length = 120

# Shell scripts
[*.{sh,bash}]
end_of_line = lf

# Dockerfiles
[Dockerfile]
indent_size = 4

# Environment files
[*.env]
insert_final_newline = false

# Lock files (don't modify)
[*.lock]
indent_style = unset
trim_trailing_whitespace = unset
insert_final_newline = unset